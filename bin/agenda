#!/bin/bash
# Live-refreshing agenda view backed by gcalcli.
# Usage: agenda [interval_seconds] [-- gcalcli args...]
#   agenda           # default 60s refresh, today + next several days
#   agenda 30        # 30s refresh
#   agenda 60 -- calw  # weekly grid view instead of agenda

INTERVAL="${1:-60}"
shift 2>/dev/null || true
if [ "${1:-}" = "--" ]; then shift; fi

GCAL_ARGS=("${@:-agenda}")

trap 'tput cnorm; exit 0' INT TERM
tput civis 2>/dev/null  # hide cursor

while true; do
    clear
    printf '\033[1;36m%s\033[0m  (refresh %ss, q/Ctrl-C to quit)\n\n' \
        "$(date '+%a %d %b %Y  %H:%M:%S')" "$INTERVAL"
    gcalcli "${GCAL_ARGS[@]}"
    # sleep but allow q to quit early
    read -t "$INTERVAL" -n 1 key 2>/dev/null && [ "$key" = "q" ] && break || true
done

tput cnorm 2>/dev/null
